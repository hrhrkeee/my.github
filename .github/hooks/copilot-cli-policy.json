{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "./scripts/session-banner.sh",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "./scripts/prompt-policy.sh",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "./scripts/pre-tool-policy.sh",
        "cwd": ".github/hooks",
        "timeoutSec": 15
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "./scripts/post-tool-quality.sh",
        "cwd": ".github/hooks",
        "timeoutSec": 20
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "./scripts/session-summary.sh",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ]
  }
}
